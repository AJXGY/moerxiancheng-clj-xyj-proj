{
  "model_config": {
    "model_name": "LLama3.1-8B",
    "model_path": "/path/to/Meta-Llama-3.1-8B",
    "model_type": "llama",
    "hidden_size": 4096,
    "num_layers": 32,
    "num_heads": 32,
    "vocab_size": 128000
  },
  "training_config": {
    "task_type": "full_training",
    "max_steps": 1000,
    "learning_rate": 1e-4,
    "warmup_steps": 100,
    "weight_decay": 0.01,
    "max_grad_norm": 1.0,
    "gradient_accumulation_steps": 1
  },
  "optimization_strategy": {
    "zero_stage": 1,
    "use_gradient_checkpointing": true,
    "use_flash_attention": true,
    "mixed_precision": "fp16"
  },
  "data_config": {
    "dataset_name": "standard_benchmark",
    "batch_size": 32,
    "micro_batch_size": 8,
    "num_workers": 4,
    "prefetch_factor": 2
  },
  "hardware_config": {
    "device_type": "musa",
    "single_gpu_config": {
      "num_gpus": 1,
      "world_size": 1,
      "rank": 0
    },
    "dual_gpu_config": {
      "num_gpus": 2,
      "world_size": 2,
      "backend": "mccl"
    }
  },
  "output_config": {
    "output_dir": "./checkpoints",
    "log_dir": "./logs",
    "save_strategy": "steps",
    "save_steps": 250,
    "logging_steps": 10
  },
  "test_scenarios": [
    {
      "name": "single_gpu_full_training",
      "num_gpus": 1,
      "task_type": "full_training",
      "max_steps": 500
    },
    {
      "name": "single_gpu_lora_training",
      "num_gpus": 1,
      "task_type": "lora_training",
      "lora_rank": 8,
      "lora_alpha": 16,
      "max_steps": 500
    },
    {
      "name": "dual_gpu_full_training",
      "num_gpus": 2,
      "task_type": "full_training",
      "max_steps": 500
    },
    {
      "name": "dual_gpu_lora_training",
      "num_gpus": 2,
      "task_type": "lora_training",
      "lora_rank": 8,
      "lora_alpha": 16,
      "max_steps": 500
    }
  ]
}
